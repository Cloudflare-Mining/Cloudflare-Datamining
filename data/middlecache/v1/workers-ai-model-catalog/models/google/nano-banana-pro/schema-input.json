{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"additionalProperties": false,
	"properties": {
		"aspect_ratio": {
			"enum": [
				"1:1",
				"3:2",
				"2:3",
				"3:4",
				"4:3",
				"4:5",
				"5:4",
				"9:16",
				"16:9",
				"21:9"
			],
			"type": "string"
		},
		"image_input": {
			"items": {
				"type": "string"
			},
			"maxItems": 3,
			"type": "array"
		},
		"image_size": {
			"enum": [
				"1K",
				"2K",
				"4K"
			],
			"type": "string"
		},
		"output_format": {
			"enum": [
				"jpg",
				"png",
				"webp"
			],
			"type": "string"
		},
		"prompt": {
			"type": "string"
		}
	},
	"required": [
		"prompt"
	],
	"type": "object"
}
