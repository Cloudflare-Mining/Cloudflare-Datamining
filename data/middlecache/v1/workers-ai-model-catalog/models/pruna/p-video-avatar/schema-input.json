{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"properties": {
		"image": {
			"description": "Input portrait image (first frame). HTTP(S) URL or data URI. Supports jpg, jpeg, png, webp.",
			"type": "string"
		},
		"audio": {
			"description": "URL of uploaded audio to drive speech. HTTP(S) URL or data URI. If both audio and voice_script are provided, audio takes priority.",
			"type": "string"
		},
		"voice": {
			"description": "Voice for generated speech.",
			"default": "Zephyr (Female)",
			"type": "string",
			"enum": [
				"Zephyr (Female)",
				"Puck (Male)",
				"Charon (Male)",
				"Kore (Female)",
				"Fenrir (Male)",
				"Leda (Female)",
				"Orus (Male)",
				"Aoede (Female)",
				"Callirrhoe (Female)",
				"Autonoe (Female)",
				"Enceladus (Male)",
				"Iapetus (Male)",
				"Umbriel (Male)",
				"Algenib (Male)",
				"Despina (Female)",
				"Erinome (Female)",
				"Laomedeia (Female)",
				"Achernar (Female)",
				"Algieba (Male)",
				"Schedar (Male)",
				"Gacrux (Female)",
				"Pulcherrima (Female)",
				"Achird (Male)",
				"Zubenelgenubi (Male)",
				"Vindemiatrix (Female)",
				"Sadachbia (Male)",
				"Sadaltager (Male)",
				"Sulafat (Female)",
				"Alnilam (Male)",
				"Rasalgethi (Male)"
			]
		},
		"voice_script": {
			"description": "Script for the person to say when no audio is uploaded.",
			"default": "",
			"type": "string"
		},
		"voice_language": {
			"description": "Output language.",
			"default": "English (US)",
			"type": "string",
			"enum": [
				"English (US)",
				"English (UK)",
				"Spanish",
				"French",
				"German",
				"Italian",
				"Portuguese (Brazil)",
				"Japanese",
				"Korean",
				"Hindi"
			]
		},
		"resolution": {
			"description": "Resolution of the video.",
			"default": "720p",
			"type": "string",
			"enum": [
				"720p",
				"1080p"
			]
		},
		"video_prompt": {
			"description": "Optional prompt for the video.",
			"default": "The person is talking.",
			"type": "string"
		},
		"voice_prompt": {
			"description": "Optional speaking style, tone, pacing or emotion instructions.",
			"default": "Say the following.",
			"type": "string"
		},
		"negative_prompt": {
			"description": "Mention what you do NOT want in the video. Disabled if empty.",
			"default": "",
			"type": "string"
		},
		"strength_negative_prompt": {
			"description": "Strength of the negative prompt (0-4).",
			"default": 0.5,
			"type": "number",
			"minimum": 0,
			"maximum": 4
		},
		"seed": {
			"description": "Random seed for reproducible generation.",
			"type": "integer",
			"minimum": -9007199254740991,
			"maximum": 9007199254740991
		},
		"disable_safety_filter": {
			"description": "Disable safety filter for prompts and input image.",
			"default": true,
			"type": "boolean"
		},
		"disable_prompt_upsampling": {
			"description": "When true, skip the prompt upsampler and pass the raw user prompt.",
			"default": false,
			"type": "boolean"
		}
	},
	"required": [
		"image",
		"voice",
		"voice_script",
		"voice_language",
		"resolution",
		"video_prompt",
		"voice_prompt",
		"negative_prompt",
		"strength_negative_prompt",
		"disable_safety_filter",
		"disable_prompt_upsampling"
	],
	"additionalProperties": {}
}
