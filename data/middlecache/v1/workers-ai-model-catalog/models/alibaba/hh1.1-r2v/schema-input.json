{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"properties": {
		"prompt": {
			"type": "string",
			"minLength": 1,
			"maxLength": 2500
		},
		"images": {
			"minItems": 1,
			"maxItems": 9,
			"type": "array",
			"items": {
				"type": "string",
				"format": "uri"
			}
		},
		"resolution": {
			"type": "string",
			"enum": [
				"720P",
				"1080P"
			]
		},
		"ratio": {
			"type": "string",
			"enum": [
				"16:9",
				"9:16",
				"3:4",
				"4:3",
				"1:1",
				"21:9",
				"9:21",
				"5:4",
				"4:5"
			]
		},
		"duration": {
			"type": "integer",
			"minimum": 3,
			"maximum": 15
		},
		"seed": {
			"type": "integer",
			"minimum": 0,
			"maximum": 2147483647
		},
		"watermark": {
			"type": "boolean"
		}
	},
	"required": [
		"prompt",
		"images"
	],
	"additionalProperties": false
}
