{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"properties": {
		"image": {
			"type": "string",
			"format": "uri"
		},
		"prompt": {
			"type": "string"
		},
		"negative_prompt": {
			"type": "string"
		},
		"resolution": {
			"type": "string",
			"enum": [
				"720P",
				"1080P"
			]
		},
		"duration": {
			"type": "integer",
			"minimum": 2,
			"maximum": 15
		},
		"seed": {
			"type": "integer",
			"minimum": 0,
			"maximum": 2147483647
		},
		"watermark": {
			"type": "boolean"
		}
	},
	"required": [
		"image"
	],
	"additionalProperties": false
}
