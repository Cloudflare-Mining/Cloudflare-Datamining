{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"additionalProperties": false,
	"properties": {
		"duration": {
			"maximum": 15,
			"minimum": 3,
			"type": "integer"
		},
		"prompt": {
			"maxLength": 2500,
			"minLength": 1,
			"type": "string"
		},
		"ratio": {
			"enum": [
				"16:9",
				"9:16",
				"1:1",
				"4:3",
				"3:4"
			],
			"type": "string"
		},
		"resolution": {
			"enum": [
				"720P",
				"1080P"
			],
			"type": "string"
		},
		"seed": {
			"maximum": 2147483647,
			"minimum": 0,
			"type": "integer"
		},
		"watermark": {
			"type": "boolean"
		}
	},
	"required": [
		"prompt"
	],
	"type": "object"
}
