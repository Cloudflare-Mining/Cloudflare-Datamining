{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"additionalProperties": false,
	"properties": {
		"aspect_ratio": {
			"enum": [
				"1:1",
				"3:4",
				"4:3",
				"9:16",
				"16:9",
				"2:3",
				"3:2",
				"9:19.5",
				"19.5:9",
				"9:20",
				"20:9",
				"1:2",
				"2:1",
				"auto"
			],
			"type": "string"
		},
		"image": {
			"additionalProperties": false,
			"properties": {
				"type": {
					"type": "string"
				},
				"url": {
					"type": "string"
				}
			},
			"required": [
				"url"
			],
			"type": "object"
		},
		"images": {
			"items": {
				"additionalProperties": false,
				"properties": {
					"type": {
						"type": "string"
					},
					"url": {
						"type": "string"
					}
				},
				"required": [
					"url"
				],
				"type": "object"
			},
			"maxItems": 10,
			"type": "array"
		},
		"mask": {
			"additionalProperties": false,
			"properties": {
				"url": {
					"type": "string"
				}
			},
			"required": [
				"url"
			],
			"type": "object"
		},
		"n": {
			"maximum": 10,
			"minimum": 1,
			"type": "integer"
		},
		"prompt": {
			"type": "string"
		},
		"quality": {
			"enum": [
				"low",
				"medium",
				"high"
			],
			"type": "string"
		},
		"resolution": {
			"enum": [
				"1k",
				"2k"
			],
			"type": "string"
		},
		"response_format": {
			"enum": [
				"url",
				"b64_json"
			],
			"type": "string"
		},
		"user": {
			"type": "string"
		}
	},
	"required": [
		"prompt"
	],
	"type": "object"
}
