{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"additionalProperties": false,
	"properties": {
		"aspect_ratio": {
			"enum": [
				"match_input_image",
				"1:1",
				"4:3",
				"3:4",
				"16:9",
				"9:16",
				"3:2",
				"2:3",
				"21:9"
			],
			"type": "string"
		},
		"enhance_prompt": {
			"type": "boolean"
		},
		"height": {
			"maximum": 4096,
			"minimum": 1024,
			"type": "integer"
		},
		"prompt": {
			"type": "string"
		},
		"size": {
			"enum": [
				"1K",
				"2K",
				"4K",
				"custom"
			],
			"type": "string"
		},
		"width": {
			"maximum": 4096,
			"minimum": 1024,
			"type": "integer"
		}
	},
	"required": [
		"prompt"
	],
	"type": "object"
}
