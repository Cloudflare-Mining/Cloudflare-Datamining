{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"additionalProperties": false,
	"properties": {
		"aspect_ratio": {
			"enum": [
				"match_input_image",
				"1:1",
				"4:3",
				"3:4",
				"16:9",
				"9:16",
				"3:2",
				"2:3",
				"21:9"
			],
			"type": "string"
		},
		"disable_safety_checker": {
			"type": "boolean"
		},
		"image_input": {
			"items": {
				"format": "uri",
				"type": "string"
			},
			"type": "array"
		},
		"max_images": {
			"maximum": 15,
			"minimum": 1,
			"type": "integer"
		},
		"prompt": {
			"type": "string"
		},
		"sequential_image_generation": {
			"enum": [
				"disabled",
				"auto"
			],
			"type": "string"
		},
		"size": {
			"enum": [
				"2K",
				"4K"
			],
			"type": "string"
		}
	},
	"required": [
		"prompt"
	],
	"type": "object"
}
