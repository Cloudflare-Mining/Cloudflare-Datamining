{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"properties": {
		"first_frame_image": {
			"description": "URL or base64 data URI of the first frame image",
			"type": "string"
		},
		"prompt": {
			"type": "string",
			"maxLength": 2000
		},
		"prompt_optimizer": {
			"default": true,
			"type": "boolean"
		},
		"fast_pretreatment": {
			"default": false,
			"type": "boolean"
		},
		"duration": {
			"default": 6,
			"anyOf": [
				{
					"type": "number",
					"const": 6
				},
				{
					"type": "number",
					"const": 10
				}
			]
		},
		"resolution": {
			"default": "768P",
			"type": "string",
			"enum": [
				"768P",
				"1080P"
			]
		},
		"callback_url": {
			"type": "string"
		}
	},
	"required": [
		"first_frame_image",
		"prompt_optimizer",
		"fast_pretreatment",
		"duration",
		"resolution"
	],
	"additionalProperties": false
}
