{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"additionalProperties": false,
	"properties": {
		"status": {
			"enum": [
				"Preparing",
				"Queueing",
				"Processing",
				"Success",
				"Fail"
			],
			"type": "string"
		},
		"task_id": {
			"type": "string"
		},
		"video": {
			"format": "uri",
			"type": "string"
		}
	},
	"required": [
		"task_id"
	],
	"type": "object"
}
