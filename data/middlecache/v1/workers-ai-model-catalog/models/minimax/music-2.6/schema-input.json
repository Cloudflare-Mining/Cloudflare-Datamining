{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"additionalProperties": false,
	"properties": {
		"bitrate": {
			"anyOf": [
				{
					"const": 32000,
					"type": "number"
				},
				{
					"const": 64000,
					"type": "number"
				},
				{
					"const": 128000,
					"type": "number"
				},
				{
					"const": 256000,
					"type": "number"
				}
			],
			"description": "Audio bitrate"
		},
		"format": {
			"description": "Audio format",
			"enum": [
				"mp3",
				"wav"
			],
			"type": "string"
		},
		"is_instrumental": {
			"default": false,
			"description": "Generate instrumental music (no vocals)",
			"type": "boolean"
		},
		"lyrics": {
			"description": "Song lyrics, using \\n to separate lines",
			"maxLength": 3500,
			"minLength": 1,
			"type": "string"
		},
		"lyrics_optimizer": {
			"default": false,
			"description": "Automatically generate lyrics based on the prompt description",
			"type": "boolean"
		},
		"prompt": {
			"description": "Description of the music style, mood, and scenario",
			"maxLength": 2000,
			"type": "string"
		},
		"sample_rate": {
			"anyOf": [
				{
					"const": 16000,
					"type": "number"
				},
				{
					"const": 24000,
					"type": "number"
				},
				{
					"const": 32000,
					"type": "number"
				},
				{
					"const": 44100,
					"type": "number"
				}
			],
			"description": "Audio sample rate"
		}
	},
	"required": [
		"prompt",
		"lyrics_optimizer",
		"is_instrumental"
	],
	"type": "object"
}
