{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"additionalProperties": false,
	"properties": {
		"duration": {
			"anyOf": [
				{
					"const": 6,
					"type": "number"
				},
				{
					"const": 10,
					"type": "number"
				}
			],
			"default": 6
		},
		"fast_pretreatment": {
			"default": false,
			"type": "boolean"
		},
		"first_frame_image": {
			"type": "string"
		},
		"prompt": {
			"maxLength": 2000,
			"type": "string"
		},
		"prompt_optimizer": {
			"default": true,
			"type": "boolean"
		},
		"resolution": {
			"default": "768P",
			"enum": [
				"768P",
				"1080P"
			],
			"type": "string"
		}
	},
	"required": [
		"prompt_optimizer",
		"fast_pretreatment",
		"duration",
		"resolution"
	],
	"type": "object"
}
