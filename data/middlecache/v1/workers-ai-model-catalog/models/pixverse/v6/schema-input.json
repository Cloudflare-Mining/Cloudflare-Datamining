{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"additionalProperties": false,
	"properties": {
		"aspect_ratio": {
			"default": "16:9",
			"description": "Video aspect ratio",
			"enum": [
				"16:9",
				"4:3",
				"1:1",
				"3:4",
				"9:16",
				"2:3",
				"3:2",
				"21:9"
			],
			"type": "string"
		},
		"duration": {
			"default": 5,
			"description": "Video duration in seconds (1 to 15)",
			"maximum": 15,
			"minimum": 1,
			"type": "integer"
		},
		"generate_audio": {
			"default": true,
			"description": "Whether to generate audio with the video",
			"type": "boolean"
		},
		"image_input": {
			"description": "Base64-encoded reference image for image-to-video generation (data:image/...;base64,...). The image will be uploaded to Pixverse automatically.",
			"type": "string"
		},
		"negative_prompt": {
			"description": "Negative text prompt",
			"maxLength": 2048,
			"type": "string"
		},
		"prompt": {
			"description": "Text prompt describing the video to generate",
			"maxLength": 2048,
			"type": "string"
		},
		"quality": {
			"default": "720p",
			"description": "Video quality",
			"enum": [
				"360p",
				"540p",
				"720p",
				"1080p"
			],
			"type": "string"
		},
		"seed": {
			"description": "Random seed for reproducibility",
			"maximum": 2147483647,
			"minimum": 0,
			"type": "integer"
		}
	},
	"required": [
		"prompt",
		"duration",
		"aspect_ratio",
		"quality",
		"generate_audio"
	],
	"type": "object"
}
