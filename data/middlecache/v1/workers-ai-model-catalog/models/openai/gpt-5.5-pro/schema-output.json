{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"additionalProperties": {},
	"properties": {
		"created_at": {
			"type": "number"
		},
		"id": {
			"type": "string"
		},
		"model": {
			"type": "string"
		},
		"object": {
			"const": "response",
			"type": "string"
		},
		"output": {
			"items": {},
			"type": "array"
		},
		"output_text": {
			"type": "string"
		},
		"status": {
			"enum": [
				"in_progress",
				"completed",
				"failed",
				"incomplete"
			],
			"type": "string"
		},
		"usage": {
			"additionalProperties": {},
			"properties": {
				"input_tokens": {
					"type": "number"
				},
				"output_tokens": {
					"type": "number"
				},
				"total_tokens": {
					"type": "number"
				}
			},
			"required": [
				"input_tokens",
				"output_tokens",
				"total_tokens"
			],
			"type": "object"
		}
	},
	"required": [
		"id",
		"object",
		"created_at",
		"model",
		"output"
	],
	"type": "object"
}
