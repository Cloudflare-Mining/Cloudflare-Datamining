									"cellText": "Security",
									"cellTextLinkUrl": null,
									"buttonText": null,
									"buttonUrl": null,
									"commonElements": null,
									"imageAssetFile": null
								},
								"cellsInRow": [
									{
										"contentfulId": "6gnXgrvGIuyEUlevdcDC4W",
										"cellText": "Features unmetered, built-in DDoS mitigation natively out-of-the-box, alongside one-click DNSSEC, advanced access controls, and custom DNS Firewall rules for Enterprise.",
										"cellTextLinkUrl": null,
										"buttonText": null,
										"buttonUrl": null,
										"commonElements": null,
										"imageAssetFile": null
									},
									{
