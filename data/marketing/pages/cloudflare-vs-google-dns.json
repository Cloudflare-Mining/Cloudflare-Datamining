								},
								"cellsInRow": [
									{
										"contentfulId": "3i6Zc2H5lrNvDZUtULaWqF",
										"cellText": "Consistently ranked as the fastest global authoritative DNS provider by independent monitors like DNSPerf, utilizing a massive Anycast network to ensure ultra-low latency everywhere.",
										"cellTextLinkUrl": null,
										"buttonText": null,
										"buttonUrl": null,
										"commonElements": null,
										"imageAssetFile": null
									},
									{
										"contentfulId": "1JsIksiQZA470khLSdCNid",
										"cellText": "Provides reliable performance, but typically trails Cloudflare in independent global speed benchmarks and operates across fewer edge locations.",
										"cellTextLinkUrl": null,
										"buttonText": null,
										"buttonUrl": null,
										"commonElements": null,
										"imageAssetFile": null
									}
								]
							},
							{
								"contentfulId": "47JK2whPVt1kEZx7lTE6QZ",
								"rowHeader2": {
									"contentfulId": "3iSWubNGdD7sHaA7ZCYyd2",
									"cellText": "Pricing",
									"cellTextLinkUrl": null,
									"buttonText": null,
									"buttonUrl": null,
									"commonElements": null,
									"imageAssetFile": null
								},
								"cellsInRow": [
									{
										"contentfulId": "5umHWOlXwy6BkXEv24ypNK",
										"cellText": "Offers a generous Free tier, plus predictable flat-rate pricing for Pro and Business plans. Unmetered DDoS protection means you are never charged for attack spikes.",
										"cellTextLinkUrl": null,
										"buttonText": null,
										"buttonUrl": null,
										"commonElements": null,
										"imageAssetFile": null
									},
									{
										"contentfulId": "28fkFgJmQVVi6c0u7K7snX",
										"cellText": "Relies on a complex pay-as-you-go model that charges per zone and per million queries. This can lead to unpredictable billing, especially if your DNS is targeted by high-volume attacks.",
										"cellTextLinkUrl": null,
										"buttonText": null,
										"buttonUrl": null,
										"commonElements": null,
										"imageAssetFile": null
									}
								]
							},
							{
								"contentfulId": "7KG2yG8EhS4JevW8OdMmU2",
								"rowHeader2": {
									"contentfulId": "3CkL7R7JYIgYFYNOqa1Igh",
									"cellText": "Redundancy",
									"cellTextLinkUrl": null,
									"buttonText": null,
									"buttonUrl": null,
									"commonElements": null,
									"imageAssetFile": null
								},
								"cellsInRow": [
									{
										"contentfulId": "7wFZyu7PXiwJs6bI5m4jN8",
										"cellText": "Resolves queries from edge locations in %{DataCenterCount} cities worldwide, ensuring DNS resolution happens as close to the end-user as possible for maximum availability.\n",
										"cellTextLinkUrl": null,
										"buttonText": null,
										"buttonUrl": null,
										"commonElements": null,
										"imageAssetFile": null
									},
									{
										"contentfulId": "6uZdDAsQ38wPuvo5OdWNrT",
										"cellText": "While backed by Google's infrastructure, Google Cloud DNS supports authoritative resolution in a significantly smaller edge footprint compared to Cloudflare.",
										"cellTextLinkUrl": null,
										"buttonText": null,
										"buttonUrl": null,
										"commonElements": null,
										"imageAssetFile": null
									}
								]
							},
							{
