{
	"POST /accounts/{account_id}/analytics/query/{dataset}/summary": {
		"description": "Returns aggregate summary stats for a dataset. Includes current-period and previous-period totals for trend comparison.\n",
		"operationId": "art-analytics-query-summary",
		"parameters": [
			{
				"description": "Cloudflare account identifier.",
				"in": "path",
				"name": "account_id",
				"required": true,
				"schema": {
					"example": "023e105f4ecef8ad9ca31a8372d0c353",
					"maxLength": 32,
					"pattern": "^[0-9a-f]{32}$",
					"type": "string"
				}
			},
			{
				"description": "Dataset name to query. Examples: `access-logins`, `gateway-http`, `gateway-dns`, `gateway-http`, `shadow-it`.\n",
				"in": "path",
				"name": "dataset",
				"required": true,
				"schema": {
					"example": "access-logins",
					"type": "string"
				}
			}
		],
		"requestBody": {
			"content": {
				"application/json": {
					"examples": {
						"access_summary": {
							"summary": "Access login summary for a week",
							"value": {
								"filters": [],
								"from": "2024-11-01T00:00:00Z",
								"groupBy": [],
								"stats": [
									"attemptsTotal"
								],
								"to": "2024-11-08T00:00:00Z"
							}
						}
					},
					"schema": {
						"allOf": [
							{
								"description": "Defines fields that all query types share.",
								"properties": {
									"filters": {
										"description": "Filters to apply before aggregating results.",
										"example": [],
										"items": {
											"description": "A filter to apply to the query.",
											"properties": {
												"name": {
													"description": "Specifies the column name to filter on. Requires a valid column for the target dataset (e.g. `country`, `allowed`, `appId`).",
													"example": "country",
													"type": "string"
												},
												"op": {
													"description": "Filter operator. Common values: `eq`, `neq`, `in`, `not_in`, `gt`, `lt`, `gte`, `lte`.\n",
													"example": "in",
													"type": "string"
												},
												"values": {
													"description": "Values to match against. Type depends on the column.",
													"example": [
														"US",
														"CA",
														"GB"
													],
													"items": {
														"oneOf": [
															{
																"type": "string"
															},
															{
																"type": "boolean"
															},
															{
																"type": "integer"
															},
															{
																"type": "number"
															}
														]
													},
													"type": "array"
												}
											},
											"required": [
												"name",
												"op",
												"values"
											],
											"type": "object"
										},
										"type": "array"
									},
									"from": {
										"description": "The start of the query time range (inclusive). RFC3339 format with timezone is required (e.g. `2024-11-05T00:00:00Z`).",
										"example": "2024-11-05T00:00:00Z",
										"format": "date-time",
										"type": "string"
									},
									"groupBy": {
										"description": "Specifies the column names to group results by. Requires valid columns for the target dataset.",
										"example": [
											"country",
											"allowed"
										],
										"items": {
											"type": "string"
										},
										"type": "array"
									},
									"stats": {
										"description": "Specifies the stat names to include in results. Requires valid stats for the target dataset (e.g. `attemptsTotal`, `bytesTotal`).",
										"example": [
											"attemptsTotal"
										],
										"items": {
											"type": "string"
										},
										"type": "array"
									},
									"to": {
										"description": "Specifies the end of the query time range (exclusive). Requires RFC3339 format with timezone.",
										"example": "2024-11-06T00:00:00Z",
										"format": "date-time",
										"type": "string"
									}
								},
								"required": [
									"from",
									"to",
									"groupBy",
									"stats",
									"filters"
								],
								"type": "object"
							}
						]
					}
				}
			},
			"required": true
		},
		"responses": {
			"200": {
				"content": {
					"application/json": {
						"examples": {
							"success": {
								"summary": "Successful summary result",
								"value": {
									"errors": [],
									"messages": [
										{
											"code": 1000,
											"message": "API in beta: expect breaking changes."
										}
									],
									"result": {
										"currentTotal": [
											{
												"attemptsTotal": 48291
											}
										],
										"previousTotal": [
											{
												"attemptsTotal": 41033
											}
										]
									},
									"success": true
								}
							}
						},
						"schema": {
							"properties": {
								"errors": {
									"example": [],
									"items": {
										"properties": {
											"code": {
												"example": 11005,
												"type": "integer"
											},
											"message": {
												"example": "art.api.parameter.invalid",
												"type": "string"
											}
										},
										"type": "object"
									},
									"type": "array"
								},
								"messages": {
									"items": {
										"properties": {
											"code": {
												"example": 1000,
												"type": "integer"
											},
											"message": {
												"example": "API in beta: expect breaking changes.",
												"type": "string"
											}
										},
										"type": "object"
									},
									"type": "array"
								},
								"result": {
									"properties": {
										"currentTotal": {
											"description": "Aggregated stats for the requested time range.",
											"example": [
												{
													"attemptsTotal": 48291
												}
											],
											"items": {
												"additionalProperties": true,
												"description": "Maps field names to values. Keys represent stat names and group-by column names. Values depend on the dataset (strings, numbers, booleans).\n",
												"example": {
													"attemptsTotal": 1234,
													"country": "US"
												},
												"type": "object"
											},
											"type": "array"
										},
										"previousTotal": {
											"description": "Aggregated stats for the equivalent preceding time range, for trend comparison.\n",
											"example": [
												{
													"attemptsTotal": 41033
												}
											],
											"items": {
												"additionalProperties": true,
												"description": "Maps field names to values. Keys represent stat names and group-by column names. Values depend on the dataset (strings, numbers, booleans).\n",
												"example": {
													"attemptsTotal": 1234,
													"country": "US"
												},
												"type": "object"
											},
											"type": "array"
										}
									},
									"required": [
										"currentTotal",
										"previousTotal"
									],
									"type": "object"
								},
								"success": {
									"example": true,
									"type": "boolean"
								}
							},
							"required": [
								"success",
								"result",
								"errors",
								"messages"
							],
							"type": "object"
						}
					}
				},
				"description": "Summary query result."
			},
			"400": {
				"content": {
					"application/json": {
						"examples": {
							"invalid_timestamp": {
								"summary": "Invalid timestamp format",
								"value": {
									"errors": [
										{
											"code": 11005,
											"message": "art.api.parameter.invalid"
										}
									],
									"messages": [
										{
											"code": 1002,
											"message": "Parameter 'from' has invalid value '2024-11-05 00:00:00'. Should be of type: 'RFC3339'"
										}
									],
									"result": null,
									"success": false
								}
							},
							"missing_body": {
								"summary": "Missing or empty request body",
								"value": {
									"errors": [
										{
											"code": 11005,
											"message": "art.api.parameter.invalid"
										}
									],
									"messages": [
										{
											"code": 1000,
											"message": "API in beta: expect breaking changes."
										}
									],
									"result": null,
									"success": false
								}
							}
						},
						"schema": {
							"properties": {
								"errors": {
									"items": {
										"properties": {
											"code": {
												"example": 11005,
												"type": "integer"
											},
											"message": {
												"example": "art.api.parameter.invalid",
												"type": "string"
											}
										},
										"type": "object"
									},
									"type": "array"
								},
								"messages": {
									"items": {
										"properties": {
											"code": {
												"example": 1000,
												"type": "integer"
											},
											"message": {
												"example": "API in beta: expect breaking changes.",
												"type": "string"
