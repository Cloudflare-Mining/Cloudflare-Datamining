											],
											"items": {
												"additionalProperties": true,
												"description": "Maps field names to values. Keys represent stat names and group-by column names. Values depend on the dataset (strings, numbers, booleans).\n",
												"example": {
													"attemptsTotal": 1234,
													"country": "US"
