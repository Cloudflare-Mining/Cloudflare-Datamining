	"POST /accounts/{account_id}/analytics/query/{dataset}/top-n": {
		"description": "Returns the top N results for a dataset by a specified stat. Includes an array of result rows, each containing the requested stats and group-by dimensions.\n",
		"operationId": "art-analytics-query-top-n",
		"parameters": [
			{
				"description": "Cloudflare account identifier.",
				"in": "path",
				"name": "account_id",
				"required": true,
				"schema": {
					"example": "023e105f4ecef8ad9ca31a8372d0c353",
					"maxLength": 32,
					"pattern": "^[0-9a-f]{32}$",
					"type": "string"
				}
			},
			{
				"description": "Dataset name to query. Examples: `access-logins`, `gateway-http`, `gateway-dns`, `gateway-http`, `shadow-it`.\n",
				"in": "path",
				"name": "dataset",
				"required": true,
				"schema": {
					"example": "gateway-http",
					"type": "string"
				}
			}
		],
		"requestBody": {
			"content": {
				"application/json": {
					"examples": {
						"top_apps_by_bytes": {
							"summary": "Top 10 shadow IT apps by bytes",
							"value": {
								"filters": [],
								"from": "2024-11-05T00:00:00Z",
								"groupBy": [
									"appName",
									"appCategory"
								],
								"n": 10,
								"orderBy": "bytesTotal",
								"stats": [
									"bytesTotal",
									"requestsTotal"
								],
								"to": "2024-11-06T00:00:00Z"
							}
						},
						"top_countries_access": {
							"summary": "Top 5 countries by login attempts",
							"value": {
								"filters": [
									{
										"name": "allowed",
										"op": "eq",
										"values": [
											false
										]
									}
								],
								"from": "2024-11-01T00:00:00Z",
								"groupBy": [
									"country"
								],
								"n": 5,
								"orderBy": "attemptsTotal",
								"stats": [
									"attemptsTotal"
								],
								"to": "2024-11-08T00:00:00Z"
							}
						}
					},
					"schema": {
						"allOf": [
							{
								"description": "Defines fields that all query types share.",
								"properties": {
									"filters": {
										"description": "Filters to apply before aggregating results.",
										"example": [],
										"items": {
											"description": "A filter to apply to the query.",
											"properties": {
												"name": {
													"description": "Specifies the column name to filter on. Requires a valid column for the target dataset (e.g. `country`, `allowed`, `appId`).",
													"example": "country",
													"type": "string"
												},
												"op": {
													"description": "Filter operator. Common values: `eq`, `neq`, `in`, `not_in`, `gt`, `lt`, `gte`, `lte`.\n",
													"example": "in",
													"type": "string"
												},
												"values": {
													"description": "Values to match against. Type depends on the column.",
													"example": [
														"US",
														"CA",
														"GB"
													],
													"items": {
														"oneOf": [
															{
																"type": "string"
															},
															{
																"type": "boolean"
															},
															{
																"type": "integer"
															},
															{
																"type": "number"
															}
														]
													},
													"type": "array"
												}
											},
											"required": [
												"name",
												"op",
												"values"
											],
											"type": "object"
										},
										"type": "array"
									},
									"from": {
										"description": "The start of the query time range (inclusive). RFC3339 format with timezone is required (e.g. `2024-11-05T00:00:00Z`).",
										"example": "2024-11-05T00:00:00Z",
										"format": "date-time",
										"type": "string"
									},
									"groupBy": {
										"description": "Specifies the column names to group results by. Requires valid columns for the target dataset.",
										"example": [
											"country",
											"allowed"
										],
										"items": {
											"type": "string"
										},
										"type": "array"
									},
									"stats": {
										"description": "Specifies the stat names to include in results. Requires valid stats for the target dataset (e.g. `attemptsTotal`, `bytesTotal`).",
										"example": [
											"attemptsTotal"
										],
										"items": {
											"type": "string"
										},
										"type": "array"
									},
									"to": {
										"description": "Specifies the end of the query time range (exclusive). Requires RFC3339 format with timezone.",
										"example": "2024-11-06T00:00:00Z",
										"format": "date-time",
										"type": "string"
									}
								},
								"required": [
									"from",
									"to",
									"groupBy",
									"stats",
									"filters"
								],
								"type": "object"
							},
							{
								"properties": {
									"n": {
										"description": "Maximum number of results to return.",
										"example": 10,
										"format": "int64",
										"minimum": 1,
										"type": "integer"
									},
									"orderBy": {
										"description": "Specifies the stat name for sorting results in descending order. Requires a valid stat for the target dataset.",
										"example": "attemptsTotal",
										"type": "string"
									}
								},
								"required": [
									"n",
									"orderBy"
								],
								"type": "object"
							}
						]
					}
				}
			},
			"required": true
		},
