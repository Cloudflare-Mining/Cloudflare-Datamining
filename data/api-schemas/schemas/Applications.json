	"GET /accounts/{accountId}/resource-library/applications": {
		"description": "Get applications with different filters.",
		"operationId": "getApplications",
		"parameters": [
			{
				"description": "Account ID.",
				"example": "023e105f4ecef8ad9ca31a8372d0c353",
				"in": "path",
				"name": "accountId",
				"required": true,
				"schema": {
					"type": "string"
				}
			},
			{
				"description": "Filter applications using key:value format. Supported filter keys:\n- name: Filter by application name (e.g., name:HR)\n- id: Filter by application ID (e.g., id:0b63249c-95bf-4cc0-a7cc-d7faaaf1dac0)\n- human_id: Filter by human-readable ID (e.g., human_id:HR)\n- hostname: Filter by hostname or support domain (e.g., hostname:portal.example.com)\n- source: Filter by application source name (e.g., source:cloudflare)\n- ip_subnet: Filter by IP subnet in CIDR notation (e.g., ip_subnet:192.168.1.0/24)\n- intel_id: Filter by Intel API ID (e.g., intel_id:498).\n.\n",
				"example": "filter=name:HR&filter=source:cloudflare&filter=intel_id:498",
				"in": "query",
				"name": "filter",
				"schema": {
					"type": "string"
				}
			},
			{
				"description": "Limit of number of results to return (max 250).",
				"in": "query",
				"name": "limit",
				"schema": {
					"default": 25,
					"type": "integer"
				}
			},
			{
				"description": "Offset of results to return.",
