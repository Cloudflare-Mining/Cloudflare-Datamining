	"PATCH /zones/{zone_id}/settings/csam_scanner_third_party": {
		"description": "Update the CSAM Scanner configuration for a zone. Allows enabling or\ndisabling CSAM scanning, updating the notification email, and\nconfiguring scanning sources.\n\nWhen a new email is provided, email verification is triggered\nautomatically. The `enabled` field is a toggle; the server may\nadjust it based on whether the notification email is verified.\n\nReturns 403 if the zone or account is locked by Trust & Safety.\n",
		"operationId": "csam-scanner-update-setting",
		"parameters": [
			{
				"description": "Identifier for the zone.",
				"in": "path",
				"name": "zone_id",
				"required": true,
				"schema": {
					"description": "Identifier for the zone.",
					"example": "023e105f4ecef8ad9ca31a8372d0c353",
					"maxLength": 32,
					"minLength": 1,
					"type": "string"
				}
			}
		],
		"requestBody": {
			"content": {
				"application/json": {
					"schema": {
						"description": "Request body for updating CSAM Scanner configuration.\n",
						"properties": {
							"id": {
								"description": "The feature identifier.",
								"enum": [
									"csam_scanner"
								],
								"example": "csam_scanner",
								"type": "string"
							},
							"value": {
								"description": "Writable CSAM Scanner feature configuration values.\n",
								"properties": {
									"email": {
										"description": "Notification email address for CSAM scan results. When changed,\nemail verification is triggered automatically.\n",
										"example": "user@example.com",
										"maxLength": 254,
										"type": "string"
									},
									"enabled": {
										"description": "Whether CSAM scanning is enabled for this zone.",
										"example": true,
										"type": "boolean"
									},
									"resend_email": {
										"description": "Set to true to trigger re-sending the email verification.\nWrite-only; never appears in responses (omitted when false).\n",
										"example": true,
										"type": "boolean"
									},
									"sources": {
										"additionalProperties": {
											"type": "boolean"
										},
										"description": "Map of scanning sources and their enabled state.",
										"example": {
											"source1": true
