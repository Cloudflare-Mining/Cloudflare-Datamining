	"POST /accounts/{account_id}/access/saml_certificates/{saml_cert_set_id}/rotate": {
		"description": "Rotates the SAML encryption certificates within the specified certificate set. This generates a new\ncertificate and moves the current certificate to the previous slot. If a previous certificate exists,\nit will be deactivated and removed.\n\nThis endpoint ensures zero-downtime rotation by maintaining both current and previous certificates \nduring the transition period, allowing IdPs time to update their configurations. Automated rotation\nhappens 30 days before a current certificate's expiration.\n",
		"operationId": "access-saml-certificates-rotate-certificate",
		"parameters": [
			{
				"in": "path",
				"name": "account_id",
				"required": true,
				"schema": {
					"description": "Identifier.",
					"example": "023e105f4ecef8ad9ca31a8372d0c353",
					"maxLength": 32,
					"type": "string",
					"x-auditable": true
				}
			},
			{
				"description": "UID of the SAML certificate set to rotate.",
				"in": "path",
				"name": "saml_cert_set_id",
				"required": true,
				"schema": {
					"description": "UUID.",
					"example": "f174e90a-fafe-4643-bbbc-4a0ed4fc8415",
