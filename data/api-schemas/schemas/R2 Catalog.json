{
	"GET /accounts/{account_id}/cloudforce-one/events/graph": {
		"description": "Expands the single-level relationship neighborhood of one or more seed nodes (event, indicator, or tag) from R2 Data Catalog. Seeds use compact id format (type:uuid), e.g. \"event:550e8400-...\". Multi-seed requests merge and deduplicate results server-side. Hydrates neighbor entities with summary data from Durable Objects. Supports filtering by relationship type and dataset scope.",
		"operationId": "get_EventGraph",
		"parameters": [
			{
				"description": "Account ID.",
				"in": "path",
				"name": "account_id",
				"required": true,
				"schema": {
					"description": "Account ID.",
					"type": "string"
				}
			},
			{
				"description": "Comma-separated compact seed ids (type:uuid). Example: seeds=event:550e8400-...,indicator:661fa920-... Provide 1–50 entries; omitting seeds returns 400.",
				"in": "query",
				"name": "seeds",
				"schema": {
					"description": "Comma-separated compact seed ids (type:uuid). Example: seeds=event:550e8400-...,indicator:661fa920-... Provide 1–50 entries; omitting seeds returns 400.",
					"items": {
						"type": "string"
					},
					"type": "array"
				}
			},
			{
				"description": "Edge direction relative to each seed: out (seed→neighbors), in (neighbors→seed), both (default).",
				"in": "query",
				"name": "direction",
				"schema": {
					"description": "Edge direction relative to each seed: out (seed→neighbors), in (neighbors→seed), both (default).",
					"type": "string"
				}
			},
			{
				"description": "Hydration strategy for neighbor nodes when expand=nodes is set. r2_join (default): use R2 JOIN query + DO fallback. do_only: use plain R2 query + hydrate all neighbors via Durable Objects.",
				"in": "query",
				"name": "hydration",
				"schema": {
					"description": "Hydration strategy for neighbor nodes when expand=nodes is set. r2_join (default): use R2 JOIN query + DO fallback. do_only: use plain R2 query + hydrate all neighbors via Durable Objects.",
					"type": "string"
				}
			},
			{
				"description": "Max neighbors per seed (default: 100, max: 1000). Values above 1000 return 400.",
				"in": "query",
				"name": "limit",
				"schema": {
					"description": "Max neighbors per seed (default: 100, max: 1000). Values above 1000 return 400.",
					"type": "number"
				}
			},
			{
				"description": "Total accumulated node cap across all seeds (default: 500, max: 1000). Values above 1000 return 400.",
				"in": "query",
				"name": "max_nodes",
				"schema": {
					"description": "Total accumulated node cap across all seeds (default: 500, max: 1000). Values above 1000 return 400.",
					"type": "number"
				}
			},
			{
				"description": "Comma-separated relationship types to filter by. Allowed: tagged_with, appears_in, related_to, caused_by, attributed_to.",
				"in": "query",
				"name": "relationshipTypes",
				"schema": {
					"description": "Comma-separated relationship types to filter by. Allowed: tagged_with, appears_in, related_to, caused_by, attributed_to.",
					"items": {
						"type": "string"
					},
					"type": "array"
				}
			},
			{
				"description": "Comma-separated dataset UUIDs to restrict neighbor scope. Intersected with ACL grants.",
				"in": "query",
				"name": "datasetIds",
				"schema": {
					"description": "Comma-separated dataset UUIDs to restrict neighbor scope. Intersected with ACL grants.",
					"items": {
						"type": "string"
					},
					"type": "array"
				}
			},
			{
				"description": "Opaque pagination token. Only valid when seeds has exactly 1 entry; 400 otherwise.",
				"in": "query",
				"name": "cursor",
				"schema": {
					"description": "Opaque pagination token. Only valid when seeds has exactly 1 entry; 400 otherwise.",
					"type": "string"
				}
			},
			{
				"description": "Comma-separated list of response sections to expand (hydrate). Allowed: `nodes`. Omitting `expand` returns identifier-only nodes.",
				"in": "query",
				"name": "expand",
				"schema": {
					"description": "Comma-separated list of response sections to expand (hydrate). Allowed: `nodes`. Omitting `expand` returns identifier-only nodes.",
					"items": {
						"type": "string"
					},
					"type": "array"
				}
			}
		],
