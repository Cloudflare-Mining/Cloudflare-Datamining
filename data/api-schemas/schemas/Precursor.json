											"readOnly": true,
											"type": "string",
											"x-auditable": true
										},
										"mode": {
											"description": "The override mode Precursor applies to requests matching an enforcement\nrule. Unlike `default_mode`, this cannot be `off`.\n",
											"enum": [
												"min-friction",
												"max-security"
											],
											"example": "max-security",
