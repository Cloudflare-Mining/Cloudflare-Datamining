{
	"GET /accounts/{account_id}/devices/client-versions": {
		"description": "Lists available WARP client versions for a specific target environment and release track. This endpoint is in Beta.",
		"operationId": "list-client-versions",
		"parameters": [
			{
				"in": "path",
				"name": "account_id",
				"required": true,
				"schema": {
					"type": "string"
				}
			},
			{
				"description": "The target environment for the client version (e.g., windows, macos).",
				"in": "query",
				"name": "target_environment",
				"required": true,
				"schema": {
					"type": "string"
				}
			},
			{
				"description": "The release track (ga for General Availability, beta for Beta releases).",
				"in": "query",
				"name": "release_track",
				"required": true,
				"schema": {
					"enum": [
						"ga",
						"beta"
					],
					"type": "string"
				}
			},
			{
				"description": "The page number to return.",
				"in": "query",
				"name": "page",
				"schema": {
					"default": 1,
					"minimum": 1,
					"type": "integer"
				}
			},
			{
				"description": "The maximum number of versions to return per page.",
				"in": "query",
				"name": "per_page",
				"schema": {
					"default": 20,
					"maximum": 100,
					"minimum": 1,
					"type": "integer"
				}
			}
