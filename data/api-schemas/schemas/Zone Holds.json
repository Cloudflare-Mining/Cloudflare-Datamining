	"GET /zones/{zone_id}/hold/{zone_name}": {
		"description": "Retrieve whether a given hostname is subject to a zone hold, and metadata about the hold.\nThis endpoint checks whether the given hostname (or any of its ancestor domains) is blocked\nby an active zone hold. If a hold with `include_subdomains` is active on an ancestor domain,\nthat hold is returned. This endpoint is used internally by SSL/COMS to check hold status\nduring zone activation.",
		"operationId": "zones-0-hold-zone-name-get",
		"parameters": [
			{
				"description": "Zone identifier. Consumed by the API gateway for routing; the backend\nhandler does not use this value directly.",
				"in": "path",
				"name": "zone_id",
				"required": true,
				"schema": {
					"description": "Identifier.",
					"example": "023e105f4ecef8ad9ca31a8372d0c353",
					"maxLength": 32,
					"type": "string",
					"x-auditable": true
				}
			},
			{
				"description": "The hostname to check for a zone hold. May be a subdomain (e.g. `subdomain.example.com`)\nor an apex domain (e.g. `example.com`). The service checks the hostname and its ancestor\ndomains for active holds with `include_subdomains` enabled.",
				"in": "path",
				"name": "zone_name",
				"required": true,
				"schema": {
					"example": "subdomain.example.com",
					"maxLength": 253,
					"pattern": "^([a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\\.)+[a-zA-Z]{2,}$",
					"type": "string"
				}
			}
		],
		"responses": {
			"200": {
				"content": {
					"application/json": {
						"schema": {
							"properties": {
								"hold": {
									"description": "Whether the hostname is currently subject to a zone hold.",
									"example": true,
									"type": "boolean"
								},
								"hold_after": {
									"description": "The RFC3339-formatted timestamp at which the hold will be automatically\nre-enabled, if the hold was temporarily disabled. Null if the hold is\npermanently enabled or not set.",
									"example": "2023-01-31T15:56:36+00:00",
									"format": "date-time",
									"nullable": true,
									"type": "string"
								},
								"include_subdomains": {
									"description": "Whether the hold extends to block subdomains of the held zone.",
									"example": false,
									"type": "boolean"
								}
							},
							"type": "object"
						}
					}
				},
