			{
				"name": "Will Allen",
				"slug": "will-allen",
				"profile_image": "https://cf-assets.www.cloudflare.com/zkvhlag99gkb/4EllgD62XLR1z6DEJVpVpu/e2841e9cea806330f4910c9ceedeec11/DSC_3850-H_Edited.jpg",
				"twitter": "@williamallen",
