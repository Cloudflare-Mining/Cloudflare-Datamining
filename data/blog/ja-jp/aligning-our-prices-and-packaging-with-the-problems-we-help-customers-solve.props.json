				"name": "Phil Winslow",
				"slug": "phil-winslow",
				"profile_image": "https://cf-assets.www.cloudflare.com/zkvhlag99gkb/2i409qNfCEc2T3smkypIK2/6b84a3fbedccc48fecd6ce07b4d088f9/Phil_Winslow.jpg",
				"publiclyIndex": true
